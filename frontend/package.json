    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^26.1.0",
    "oxlint": "^1.69.0",
    "prettier": "^3.5.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.0.0"
